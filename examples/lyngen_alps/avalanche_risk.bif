// Bayesian network for avalanche risk assessment
// Study area: Lyngen Alps, Tromsø county, northern Norway
//
// Structure:
//   slope_angle ──┐
//                  ├──► terrain_factor ──┐
//   sun_exposure ──┤                     │
//   forest_cover ──┘                     ├──► avalanche_risk
//   wind_load ──┐                        │
//                ├──► weather_factor ────┘
//   recent_snow ─┤
//   temperature ─┘

network avalanche_risk_bn {}

// ── Root nodes ──────────────────────────────────────────────────────────────

variable slope_angle {
  type discrete [ 4 ] { flat, gentle, steep, extreme };
}

variable sun_exposure {
  type discrete [ 4 ] { north, east, west, south };
}

variable forest_cover {
  type discrete [ 3 ] { sparse, moderate, dense };
}

variable recent_snow {
  type discrete [ 3 ] { light, moderate, heavy };
}

variable temperature {
  type discrete [ 3 ] { cold, moderate, warming };
}

variable wind_load {
  type discrete [ 3 ] { low, moderate, high };
}

// ── Intermediate nodes ───────────────────────────────────────────────────────

variable terrain_factor {
  type discrete [ 3 ] { low, medium, high };
}

variable weather_factor {
  type discrete [ 3 ] { stable, elevated, dangerous };
}

// ── Output node ──────────────────────────────────────────────────────────────

variable avalanche_risk {
  type discrete [ 2 ] { low, high };
}

// ── Root node priors (replaced by data at inference time) ────────────────────

probability ( slope_angle ) {
  table 0.25, 0.25, 0.25, 0.25;
}

probability ( sun_exposure ) {
  table 0.25, 0.25, 0.25, 0.25;
}

probability ( forest_cover ) {
  table 0.333, 0.333, 0.334;
}

probability ( recent_snow ) {
  table 0.333, 0.333, 0.334;
}

probability ( temperature ) {
  table 0.333, 0.333, 0.334;
}

probability ( wind_load ) {
  table 0.333, 0.333, 0.334;
}

// ── P(terrain_factor | slope_angle, sun_exposure, forest_cover) ───────────────
// Discretization: slope_angle ← [0, 5, 25, 40, 90]°
//                 sun_exposure ← aspect quadrant; risk order: north > east > west > south
//                   north (N-facing): shadowed, wind-loaded — highest risk
//                   east              higher risk (morning sun only, cold nights)
//                   west              moderate risk (afternoon sun)
//                   south (S-facing): sun-exposed, snow consolidates — lowest risk
//                 forest_cover ← elevation-derived; dense forest anchors snow
// P(low, medium, high) for each parent combination:

probability ( terrain_factor | slope_angle, sun_exposure, forest_cover ) {
  // ── sparse (alpine zone: little snow anchoring) ─────────────────────────
  (flat,    north, sparse)   0.970, 0.020, 0.010;
  (flat,    east,  sparse)   0.980, 0.015, 0.005;
  (flat,    west,  sparse)   0.980, 0.015, 0.005;
  (flat,    south, sparse)   0.990, 0.009, 0.001;
  (gentle,  north, sparse)   0.750, 0.180, 0.070;
  (gentle,  east,  sparse)   0.820, 0.130, 0.050;
  (gentle,  west,  sparse)   0.860, 0.110, 0.030;
  (gentle,  south, sparse)   0.900, 0.080, 0.020;
  (steep,   north, sparse)   0.100, 0.350, 0.550;
  (steep,   east,  sparse)   0.180, 0.450, 0.370;
  (steep,   west,  sparse)   0.220, 0.500, 0.280;
  (steep,   south, sparse)   0.250, 0.550, 0.200;
  (extreme, north, sparse)   0.080, 0.270, 0.650;
  (extreme, east,  sparse)   0.120, 0.350, 0.530;
  (extreme, west,  sparse)   0.160, 0.400, 0.440;
  (extreme, south, sparse)   0.200, 0.450, 0.350;
  // ── moderate (~30 % reduction in P(high)) ───────────────────────────────
  (flat,    north, moderate) 0.970, 0.023, 0.007;
  (flat,    east,  moderate) 0.980, 0.017, 0.003;
  (flat,    west,  moderate) 0.980, 0.017, 0.003;
  (flat,    south, moderate) 0.990, 0.009, 0.001;
  (gentle,  north, moderate) 0.800, 0.170, 0.030;
  (gentle,  east,  moderate) 0.860, 0.110, 0.030;
  (gentle,  west,  moderate) 0.890, 0.090, 0.020;
  (gentle,  south, moderate) 0.920, 0.070, 0.010;
  (steep,   north, moderate) 0.180, 0.440, 0.380;
  (steep,   east,  moderate) 0.270, 0.480, 0.250;
  (steep,   west,  moderate) 0.310, 0.500, 0.190;
  (steep,   south, moderate) 0.350, 0.500, 0.150;
  (extreme, north, moderate) 0.110, 0.350, 0.540;
  (extreme, east,  moderate) 0.160, 0.410, 0.430;
  (extreme, west,  moderate) 0.210, 0.440, 0.350;
  (extreme, south, moderate) 0.260, 0.490, 0.250;
  // ── dense (~55 % reduction in P(high)) ──────────────────────────────────
  (flat,    north, dense)    0.975, 0.020, 0.005;
  (flat,    east,  dense)    0.983, 0.015, 0.002;
  (flat,    west,  dense)    0.983, 0.015, 0.002;
  (flat,    south, dense)    0.993, 0.006, 0.001;
  (gentle,  north, dense)    0.870, 0.110, 0.020;
  (gentle,  east,  dense)    0.910, 0.070, 0.020;
  (gentle,  west,  dense)    0.930, 0.060, 0.010;
  (gentle,  south, dense)    0.960, 0.030, 0.010;
  (steep,   north, dense)    0.280, 0.470, 0.250;
  (steep,   east,  dense)    0.380, 0.440, 0.180;
  (steep,   west,  dense)    0.430, 0.450, 0.120;
  (steep,   south, dense)    0.470, 0.420, 0.110;
  (extreme, north, dense)    0.150, 0.420, 0.430;
  (extreme, east,  dense)    0.210, 0.460, 0.330;
  (extreme, west,  dense)    0.270, 0.470, 0.260;
  (extreme, south, dense)    0.330, 0.480, 0.190;
}

// ── P(weather_factor | recent_snow, temperature, wind_load) ──────────────────
// Discretization: recent_snow ← [0, 15, 35, 150] cm
//                 temperature ← [-40, -8, -2, 15]°C
//                 wind_load   ← [0, 5, 15, 50] m/s; high wind causes slab formation
// Snow is the primary driver — the gap between moderate and heavy is large.
// P(stable, elevated, dangerous) for each parent combination:

probability ( weather_factor | recent_snow, temperature, wind_load ) {
  // ── low wind (baseline) ─────────────────────────────────────────────────
  (light,    cold,    low)      0.900, 0.085, 0.015;
  (light,    moderate,low)      0.830, 0.140, 0.030;
  (light,    warming, low)      0.620, 0.310, 0.070;
  (moderate, cold,    low)      0.470, 0.380, 0.150;
  (moderate, moderate,low)      0.320, 0.430, 0.250;
  (moderate, warming, low)      0.140, 0.420, 0.440;
  (heavy,    cold,    low)      0.100, 0.280, 0.620;
  (heavy,    moderate,low)      0.050, 0.180, 0.770;
  (heavy,    warming, low)      0.020, 0.080, 0.900;
  // ── moderate wind ───────────────────────────────────────────────────────
  (light,    cold,    moderate) 0.860, 0.110, 0.030;
  (light,    moderate,moderate) 0.770, 0.180, 0.050;
  (light,    warming, moderate) 0.550, 0.350, 0.100;
  (moderate, cold,    moderate) 0.370, 0.400, 0.230;
  (moderate, moderate,moderate) 0.220, 0.430, 0.350;
  (moderate, warming, moderate) 0.080, 0.370, 0.550;
  (heavy,    cold,    moderate) 0.060, 0.240, 0.700;
  (heavy,    moderate,moderate) 0.030, 0.150, 0.820;
  (heavy,    warming, moderate) 0.010, 0.060, 0.930;
  // ── high wind (strong slab risk) ────────────────────────────────────────
  (light,    cold,    high)     0.720, 0.210, 0.070;
  (light,    moderate,high)     0.600, 0.300, 0.100;
  (light,    warming, high)     0.380, 0.430, 0.190;
  (moderate, cold,    high)     0.230, 0.420, 0.350;
  (moderate, moderate,high)     0.130, 0.380, 0.490;
  (moderate, warming, high)     0.050, 0.270, 0.680;
  (heavy,    cold,    high)     0.030, 0.180, 0.790;
  (heavy,    moderate,high)     0.015, 0.105, 0.880;
  (heavy,    warming, high)     0.005, 0.045, 0.950;
}

// ── P(avalanche_risk | terrain_factor, weather_factor) ───────────────────────
// P(low, high) for each parent combination.
// Derived from the 3-state CPT by splitting medium 50/50 into low and high:

probability ( avalanche_risk | terrain_factor, weather_factor ) {
  (low,    stable)     0.93, 0.07;
  (low,    elevated)   0.77, 0.23;
  (low,    dangerous)  0.53, 0.47;
  (medium, stable)     0.59, 0.41;
  (medium, elevated)   0.36, 0.64;
  (medium, dangerous)  0.16, 0.84;
  (high,   stable)     0.38, 0.62;
  (high,   elevated)   0.15, 0.85;
  (high,   dangerous)  0.05, 0.95;
}
